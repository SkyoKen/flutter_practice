# Dart / Flutter
.dart_tool/
.packages
build/
# This is an application, so keep pubspec.lock tracked for reproducible builds.
.flutter-plugins
.flutter-plugins-dependencies

# Dartdoc and coverage output
doc/api/
coverage/

# Local environment files
.env*

# Local OS / editor files
.DS_Store
.idea/
.vscode/
*.iml

# Avoid committing generated JavaScript files from Dart builds.
# Do not ignore plain *.js here; web/ may contain hand-written JavaScript.
*.dart.js
*.info.json      # Produced by the --dump-info flag.
*.js_
*.js.deps
*.js.map
